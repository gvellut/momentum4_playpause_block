{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "swift: Build Debug Momentum4PlayPauseBlock",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/sign-built-product.sh",
            "args": [
                "Momentum4PlayPauseBlock",
                "debug"
            ],
            "group": "build",
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Release Momentum4PlayPauseBlock",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/sign-built-product.sh",
            "args": [
                "Momentum4PlayPauseBlock",
                "release"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Debug Momentum4PlayPauseBlockCLI",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/sign-built-product.sh",
            "args": [
                "Momentum4PlayPauseBlockCLI",
                "debug"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Release Momentum4PlayPauseBlockCLI",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/sign-built-product.sh",
            "args": [
                "Momentum4PlayPauseBlockCLI",
                "release"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Debug Tests",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/swift-package.sh",
            "args": [
                "build",
                "--build-tests"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Release Tests",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/swift-package.sh",
            "args": [
                "build",
                "-c",
                "release",
                "--build-tests"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Run Momentum4PlayPauseBlock",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/run-signed-product.sh",
            "args": [
                "Momentum4PlayPauseBlock",
                "debug"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Run Momentum4PlayPauseBlockCLI",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/run-signed-product.sh",
            "args": [
                "Momentum4PlayPauseBlockCLI",
                "debug",
                "--",
                "--bluetooth-address",
                "80:C3:BA:82:06:6B"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Test Momentum4PlayPauseBlock",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/swift-package.sh",
            "args": [
                "test"
            ],
            "problemMatcher": [
                "$swift"
            ]
        },
        {
            "label": "swift: Build Signed App Bundle",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build-app.sh",
            "group": "build",
            "problemMatcher": [
                "$swift"
            ]
        }
    ]
}
